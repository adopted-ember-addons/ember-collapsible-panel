{
  "private": true,
  "repository": {
    "type": "git",
    "url": "https://github.com/adopted-ember-addons/ember-collapsible-panel.git"
  },
  "license": "MIT",
  "author": "TEDconf and contributors",
  "scripts": {
    "build": "pnpm -F test-app build -o ../dist",
    "lint": "pnpm -F test-app -F ember-collapsible-panel lint",
    "lint:fix": "pnpm --filter '*' lint:fix",
    "prepare": "pnpm build",
    "start": "pnpm run \"/(start:addon|start:test-app)/\"",
    "start:addon": "pnpm --filter ember-collapsible-panel start --no-watch.clearScreen",
    "start:test-app": "pnpm --filter test-app start",
    "test": "pnpm -F test-app test",
    "test:ember": "pnpm -F test-app test:ember",
    "test:ember-compatibility": "pnpm -F test-app test:ember-compatibility"
  },
  "devDependencies": {
    "prettier": "^3.0.3",
    "prettier-plugin-ember-template-tag": "^2.0.2",
    "release-plan": "^0.18.0"
  },
  "engines": {
    "node": "14.* || 16.* || 18.* || >= 20"
  }
}
