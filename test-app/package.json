{
  "name": "test-app",
  "version": "0.0.0",
  "private": true,
  "description": "Test app for ember-collapsible-panel addon",
  "repository": "",
  "license": "MIT",
  "author": "",
  "directories": {
    "doc": "doc",
    "test": "tests"
  },
  "scripts": {
    "build": "ember build --environment=production",
    "lint": "pnpm run \"/(lint:css|lint:hbs|lint:js)/\"",
    "lint:css": "stylelint \"**/*.css\"",
    "lint:css:fix": "pnpm run lint:css --fix",
    "lint:fix": "pnpm run \"/(lint:hbs:fix|lint:css:fix|lint:js:fix)/\"",
    "lint:hbs": "ember-template-lint .",
    "lint:hbs:fix": "ember-template-lint . --fix",
    "lint:js": "eslint . --cache",
    "lint:js:fix": "eslint . --fix",
    "start": "ember serve",
    "test": "pnpm run \"/(test:ember|test:ember-compatibility|lint)/\"",
    "test:ember": "ember test",
    "test:ember-compatibility": "ember try:each"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@babel/eslint-parser": "^7.25.1",
    "@babel/plugin-proposal-decorators": "^7.24.7",
    "@ember/optional-features": "^2.1.0",
    "@ember/string": "^4.0.0",
    "@ember/test-helpers": "^3.3.1",
    "@embroider/test-setup": "4.0.0",
    "@glimmer/component": "^1.1.2",
    "@glimmer/tracking": "^1.1.2",
    "bootstrap": "^3.3.7",
    "broccoli-asset-rev": "^3.0.0",
    "ember-auto-import": "^2.8.1",
    "ember-cli": "~5.12.0",
    "ember-cli-app-version": "^7.0.0",
    "ember-cli-babel": "^8.2.0",
    "ember-cli-clean-css": "^3.0.0",
    "ember-cli-dependency-checker": "^3.3.2",
    "ember-cli-htmlbars": "^6.3.0",
    "ember-cli-inject-live-reload": "^2.1.0",
    "ember-cli-sri": "^2.1.1",
    "ember-cli-terser": "^4.0.2",
    "ember-code-snippet": "^3.0.0",
    "ember-data": "~5.3.8",
    "ember-fetch": "^8.1.2",
    "liquid-fire": "^0.36.0",
    "ember-load-initializers": "^2.1.2",
    "ember-modifier": "^4.2.0",
    "ember-page-title": "^8.2.3",
    "ember-qunit": "^8.1.0",
    "ember-resolver": "^13.0.0",
    "ember-source": "~5.4.0",
    "ember-source-channel-url": "^3.0.0",
    "ember-template-lint": "^7.9.0",
    "ember-try": "^4.0.0",
    "@eslint/js": "^9.17.0",
    "eslint": "^9.17.0",
    "eslint-config-prettier": "^10.1.5",
    "eslint-plugin-ember": "^12.3.3",
    "eslint-plugin-n": "^17.15.1",
    "eslint-plugin-qunit": "^8.1.2",
    "globals": "^16.1.0",
    "lint-to-the-future": "^2.0.0",
    "lint-to-the-future-ember-template": "^1.2.0",
    "lint-to-the-future-eslint": "^2.0.1",
    "lint-to-the-future-stylelint": "^1.0.0",
    "loader.js": "^4.7.0",
    "prettier": "^3.3.3",
    "prettier-plugin-ember-template-tag": "^2.0.2",
    "qunit": "^2.22.0",
    "qunit-dom": "^3.2.1",
    "release-plan": "^0.8.0",
    "stylelint": "^16.26.1",
    "stylelint-config-standard": "^36.0.1",
    "tracked-built-ins": "^3.3.0",
    "velocity-animate": "^1.5.2",
    "webpack": "^5.95.0"
  },
  "engines": {
    "node": ">= 18"
  },
  "ember": {
